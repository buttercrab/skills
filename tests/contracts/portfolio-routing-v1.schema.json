{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:skills-portfolio:routing:v1",
  "title": "portfolio routing contract family v1",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "schema_version": {},
    "portfolio_id": {},
    "canonical_owner": {},
    "generated_fields": {},
    "portfolio_skills": {},
    "role_taxonomy": {},
    "external_routes": {},
    "precedence_rules": {},
    "unavailable_capability_policy": {},
    "rows": {},
    "routing_cases": {},
    "routing_rubrics": {},
    "canonical_contract": {},
    "visibility": {},
    "cases": {},
    "expected_answer_catalog": {},
    "rubric_catalog": {},
    "default_rubric_keys": {},
    "critical_case_ids": {},
    "case_overrides": {},
    "editable_truths": {},
    "mappings": {}
  },
  "oneOf": [
    {
      "$ref": "#/$defs/contract"
    },
    {
      "$ref": "#/$defs/case_catalog"
    },
    {
      "$ref": "#/$defs/prompt_catalog"
    },
    {
      "$ref": "#/$defs/rubric_policy"
    },
    {
      "$ref": "#/$defs/source_map"
    }
  ],
  "$defs": {
    "agent_projection": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "display_name",
        "short_description",
        "default_prompt",
        "allow_implicit_invocation"
      ],
      "properties": {
        "display_name": {
          "type": "string",
          "minLength": 1
        },
        "short_description": {
          "type": "string",
          "minLength": 1,
          "maxLength": 96
        },
        "default_prompt": {
          "type": "string",
          "minLength": 1
        },
        "allow_implicit_invocation": {
          "type": [
            "boolean",
            "null"
          ]
        }
      }
    },
    "body_assertions": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "required",
        "forbidden"
      ],
      "properties": {
        "required": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "forbidden": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "fallback": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "condition",
        "route",
        "result"
      ],
      "properties": {
        "condition": {
          "type": "string",
          "minLength": 1
        },
        "route": {
          "type": "string",
          "minLength": 1
        },
        "result": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "composition": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "route",
        "relation"
      ],
      "properties": {
        "route": {
          "type": "string",
          "minLength": 1
        },
        "relation": {
          "enum": [
            "gateway",
            "overlay",
            "evidence-lens",
            "transport",
            "content-owner",
            "mechanics",
            "fallback"
          ]
        }
      }
    },
    "role_definition": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "field",
        "relation",
        "cardinality",
        "description",
        "allowed_routes"
      ],
      "properties": {
        "field": {
          "enum": [
            "outer_owner",
            "gateways",
            "overlays",
            "evidence_lenses",
            "mechanics",
            "transports",
            "content_owners",
            "fallbacks"
          ]
        },
        "relation": {
          "enum": [
            "outer",
            "gateway",
            "overlay",
            "evidence-lens",
            "mechanics",
            "transport",
            "content-owner",
            "fallback"
          ]
        },
        "cardinality": {
          "enum": [
            "exactly-one",
            "zero-or-more"
          ]
        },
        "description": {
          "type": "string",
          "minLength": 1
        },
        "allowed_routes": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "external_route": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "route",
        "description",
        "legal_compositions"
      ],
      "properties": {
        "route": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string",
          "minLength": 1
        },
        "legal_compositions": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/composition"
          }
        }
      }
    },
    "row": {
      "type": "object",
      "additionalProperties": false,
        "required": [
          "skill",
          "case_family",
          "routing_role",
        "portfolio_position",
        "positive_request_classes",
        "triggers",
        "exclusions",
        "fallbacks",
        "state_owner",
        "legal_compositions",
        "precedence",
        "forbidden_actions",
        "package_projection",
        "body_assertions"
      ],
        "properties": {
          "skill": {
          "enum": [
            "align-work",
            "audit-technical-work",
            "execute-goal-loop",
            "front-agent-orchestration",
            "agent-mail",
            "write-task-handoff",
            "propagate-contract-changes",
            "refactor-by-invariant",
            "brief-linked-evidence",
            "map-technical-landscapes",
            "mine-history-tool-landscapes"
            ]
          },
          "case_family": {
            "type": "string",
            "pattern": "^[a-z][a-z-]*$"
          },
          "routing_role": {
          "enum": [
            "outer",
            "overlay",
            "gateway",
            "transport",
            "content",
            "mechanics",
            "research"
          ]
        },
        "portfolio_position": {
          "type": "string",
          "minLength": 1
        },
        "positive_request_classes": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "triggers": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "exclusions": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "fallbacks": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/fallback"
          }
        },
        "state_owner": {
          "type": "string",
          "minLength": 1
        },
        "legal_compositions": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/composition"
          }
        },
        "precedence": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "forbidden_actions": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "package_projection": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "frontmatter_description",
            "agent"
          ],
          "properties": {
            "frontmatter_description": {
              "type": "string",
              "minLength": 1
            },
            "agent": {
              "$ref": "#/$defs/agent_projection"
            }
          }
        },
        "body_assertions": {
          "$ref": "#/$defs/body_assertions"
        }
      }
    },
    "contract": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schema_version",
        "portfolio_id",
        "canonical_owner",
        "generated_fields",
        "portfolio_skills",
        "role_taxonomy",
        "external_routes",
        "precedence_rules",
        "unavailable_capability_policy",
        "rows",
        "routing_cases",
        "routing_rubrics"
      ],
      "properties": {
        "schema_version": {
          "const": "portfolio-routing/v1"
        },
        "portfolio_id": {
          "const": "jaeyong-skills"
        },
        "canonical_owner": {
          "const": "tests/portfolio-routing-v1.json"
        },
        "generated_fields": {
          "type": "array",
          "const": [
            "SKILL.md frontmatter.description",
            "agents/openai.yaml interface",
            "SKILL.md generated routing contract block",
            "agents/openai.yaml routing row digest",
            "routing case, prompt, and rubric catalogs"
          ]
        },
        "portfolio_skills": {
          "type": "array",
          "const": [
            "align-work",
            "audit-technical-work",
            "execute-goal-loop",
            "front-agent-orchestration",
            "agent-mail",
            "write-task-handoff",
            "propagate-contract-changes",
            "refactor-by-invariant",
            "brief-linked-evidence",
            "map-technical-landscapes",
            "mine-history-tool-landscapes"
          ]
        },
        "role_taxonomy": {
          "type": "array",
          "minItems": 8,
          "maxItems": 8,
          "items": {
            "$ref": "#/$defs/role_definition"
          }
        },
        "external_routes": {
          "type": "array",
          "minItems": 5,
          "maxItems": 5,
          "items": {
            "$ref": "#/$defs/external_route"
          }
        },
        "precedence_rules": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "unavailable_capability_policy": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "rows": {
          "type": "array",
          "minItems": 11,
          "maxItems": 11,
          "items": {
            "$ref": "#/$defs/row"
          }
        },
        "routing_cases": {
          "type": "array",
          "minItems": 28,
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/case"
          }
        },
        "routing_rubrics": {
          "$ref": "#/$defs/embedded_rubric_policy"
        }
      }
    },
    "expected_route": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "outer_owner",
        "gateways",
        "overlays",
        "evidence_lenses",
        "mechanics",
        "transports",
        "content_owners",
        "fallbacks",
        "forbidden_actions"
      ],
      "properties": {
        "outer_owner": {
          "type": "string",
          "minLength": 1
        },
        "gateways": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "overlays": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "evidence_lenses": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "mechanics": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "transports": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "content_owners": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "fallbacks": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "forbidden_actions": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "case": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "kind",
        "family",
        "prompt",
        "expected"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9-]*$"
        },
        "kind": {
          "enum": [
            "positive",
            "negative",
            "overlap"
          ]
        },
        "family": {
          "type": "string",
          "minLength": 1
        },
        "prompt": {
          "type": "string",
          "minLength": 1
        },
        "expected": {
          "$ref": "#/$defs/expected_route"
        }
      }
    },
    "case_catalog": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schema_version",
        "canonical_contract",
        "visibility",
        "cases"
      ],
      "properties": {
        "schema_version": {
          "const": "portfolio-routing-cases/v1"
        },
        "canonical_contract": {
          "const": "tests/portfolio-routing-v1.json"
        },
        "visibility": {
          "const": "evaluator-only"
        },
        "cases": {
          "type": "array",
          "minItems": 28,
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/case"
          }
        }
      }
    },
    "prompt_case": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "kind", "family", "prompt"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9-]*$"
        },
        "kind": {
          "enum": ["positive", "negative", "overlap"]
        },
        "family": {
          "type": "string",
          "minLength": 1
        },
        "prompt": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "prompt_catalog": {
      "type": "object",
      "additionalProperties": false,
      "required": ["schema_version", "canonical_contract", "visibility", "cases"],
      "properties": {
        "schema_version": {
          "const": "portfolio-routing-prompts/v1"
        },
        "canonical_contract": {
          "const": "tests/portfolio-routing-v1.json"
        },
        "visibility": {
          "const": "trial-input"
        },
        "cases": {
          "type": "array",
          "minItems": 28,
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/prompt_case"
          }
        }
      }
    },
    "rubric_definition": {
      "type": "object",
      "additionalProperties": false,
      "required": ["key", "description"],
      "properties": {
        "key": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9-]*$"
        },
        "description": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "rubric_override": {
      "type": "object",
      "additionalProperties": false,
      "required": ["case_id", "add"],
      "properties": {
        "case_id": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9-]*$"
        },
        "add": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9-]*$"
          }
        }
      }
    },
    "embedded_rubric_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "rubric_catalog",
        "default_rubric_keys",
        "critical_case_ids",
        "case_overrides"
      ],
      "properties": {
        "rubric_catalog": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/rubric_definition"
          }
        },
        "default_rubric_keys": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9-]*$"
          }
        },
        "critical_case_ids": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9-]*$"
          }
        },
        "case_overrides": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/rubric_override"
          }
        }
      }
    },
    "rubric_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schema_version",
        "canonical_contract",
        "expected_answer_catalog",
        "visibility",
        "rubric_catalog",
        "default_rubric_keys",
        "critical_case_ids",
        "case_overrides"
      ],
      "properties": {
        "schema_version": {
          "const": "portfolio-routing-rubrics/v1"
        },
        "canonical_contract": {
          "const": "tests/portfolio-routing-v1.json"
        },
        "expected_answer_catalog": {
          "const": "tests/portfolio-routing-cases-v1.json"
        },
        "visibility": {
          "const": "evaluator-only"
        },
        "rubric_catalog": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/rubric_definition"
          }
        },
        "default_rubric_keys": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9-]*$"
          }
        },
        "critical_case_ids": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9-]*$"
          }
        },
        "case_overrides": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/rubric_override"
          }
        }
      }
    },
    "mapping": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "canonical_fields",
        "consumer",
        "validation"
      ],
      "properties": {
        "canonical_fields": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "consumer": {
          "type": "string",
          "minLength": 1
        },
        "validation": {
          "enum": [
            "exact-projection",
            "required-and-forbidden-phrases",
            "legal-route-reference",
            "case-route-parity",
            "raw-prompt-projection",
            "evaluator-rubric-reference",
            "exact-row-digest",
            "exact-projection-with-single-marker-pair"
          ]
        }
      }
    },
    "source_map": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schema_version",
        "canonical_owner",
        "editable_truths",
        "mappings"
      ],
      "properties": {
        "schema_version": {
          "const": "portfolio-routing-source-map/v1"
        },
        "canonical_owner": {
          "const": "tests/portfolio-routing-v1.json"
        },
        "editable_truths": {
          "type": "array",
          "const": [
            "tests/portfolio-routing-v1.json"
          ]
        },
        "mappings": {
          "type": "array",
          "minItems": 8,
          "items": {
            "$ref": "#/$defs/mapping"
          }
        }
      }
    },
    "hash": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    }
  }
}
