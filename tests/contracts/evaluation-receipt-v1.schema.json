{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:skills-portfolio:evaluation-receipt:v1",
  "title": "evaluation-receipt/v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "receipt_type",
    "schema_version",
    "receipt_id",
    "packet_id",
    "packet_revision",
    "protected_digest",
    "repository_root",
    "manifest_algorithm_version",
    "timestamp",
    "evaluation_component_id",
    "evaluation_component_digest",
    "trial_receipt_id",
    "trial_receipt_hash",
    "evaluator_id",
    "case_id",
    "run_ordinal",
    "source_digest",
    "prompt_digest",
    "output_schema_digest",
    "isolation_digest",
    "runner_digest",
    "runner_schema_version",
    "command_policy_digest",
    "retry_policy_digest",
    "status_policy_digest",
    "tool_policy_digest",
    "data_policy_digest",
    "network_policy_digest",
    "mutation_policy_digest",
    "model",
    "reasoning_effort",
    "local_run_id",
    "provider_thread_id",
    "fresh_session_marker",
    "attempt_number",
    "automatic_retry",
    "run_manifest_digest",
    "event_stream_digest",
    "raw_batch_output_hash",
    "raw_output_hash",
    "pre_state_digest",
    "post_state_digest",
    "rubric_keys",
    "rubric_digest",
    "dispositions"
  ],
  "properties": {
    "receipt_type": {"const": "evaluation-receipt/v1"},
    "schema_version": {"const": 1},
    "receipt_id": {"$ref": "#/$defs/uuid"},
    "packet_id": {"$ref": "#/$defs/uuid"},
    "packet_revision": {"type": "integer", "minimum": 1},
    "protected_digest": {"$ref": "#/$defs/hash"},
    "repository_root": {"type": "string", "minLength": 1},
    "manifest_algorithm_version": {"const": "portfolio-source-manifest/v1"},
    "timestamp": {"type": "string", "format": "date-time"},
    "evaluation_component_id": {"$ref": "#/$defs/uuid"},
    "evaluation_component_digest": {"$ref": "#/$defs/hash"},
    "trial_receipt_id": {"$ref": "#/$defs/uuid"},
    "trial_receipt_hash": {"$ref": "#/$defs/hash"},
    "evaluator_id": {"$ref": "#/$defs/uuid"},
    "case_id": {"type": "string", "minLength": 1},
    "run_ordinal": {"type": "integer", "minimum": 1, "maximum": 3},
    "source_digest": {"$ref": "#/$defs/hash"},
    "prompt_digest": {"$ref": "#/$defs/hash"},
    "output_schema_digest": {"$ref": "#/$defs/hash"},
    "isolation_digest": {"$ref": "#/$defs/hash"},
    "runner_digest": {"$ref": "#/$defs/hash"},
    "runner_schema_version": {"type": "string", "minLength": 1},
    "command_policy_digest": {"$ref": "#/$defs/hash"},
    "retry_policy_digest": {"$ref": "#/$defs/hash"},
    "status_policy_digest": {"$ref": "#/$defs/hash"},
    "tool_policy_digest": {"$ref": "#/$defs/hash"},
    "data_policy_digest": {"$ref": "#/$defs/hash"},
    "network_policy_digest": {"$ref": "#/$defs/hash"},
    "mutation_policy_digest": {"$ref": "#/$defs/hash"},
    "model": {"type": "string", "minLength": 1},
    "reasoning_effort": {"type": "string", "minLength": 1},
    "local_run_id": {"$ref": "#/$defs/uuid"},
    "provider_thread_id": {"$ref": "#/$defs/uuid"},
    "fresh_session_marker": {"$ref": "#/$defs/uuid"},
    "attempt_number": {"const": 1},
    "automatic_retry": {"const": false},
    "run_manifest_digest": {"$ref": "#/$defs/hash"},
    "event_stream_digest": {"$ref": "#/$defs/hash"},
    "raw_batch_output_hash": {"$ref": "#/$defs/hash"},
    "raw_output_hash": {"$ref": "#/$defs/hash"},
    "pre_state_digest": {"$ref": "#/$defs/hash"},
    "post_state_digest": {"$ref": "#/$defs/hash"},
    "rubric_keys": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {"type": "string", "minLength": 1}
    },
    "rubric_digest": {"$ref": "#/$defs/hash"},
    "dispositions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["rubric_key", "verdict", "evidence"],
        "properties": {
          "rubric_key": {"type": "string", "minLength": 1},
          "verdict": {"enum": ["pass", "fail"]},
          "evidence": {"type": "string", "minLength": 1}
        }
      }
    }
  },
  "$defs": {
    "hash": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "uuid": {"type": "string", "format": "uuid"}
  }
}
