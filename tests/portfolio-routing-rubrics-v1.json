  "rubric_catalog": [
    {
      "key": "outer-owner",
      "description": "The response selects exactly the canonical task-level outer owner. Only native Codex, Align, or standalone Audit may occupy this field; gateways and domain workflows stay in their own roles."
    },
    {
      "key": "legal-composition",
      "description": "Every selected gateway, overlay, evidence lens, mechanic, transport, content owner, and fallback exactly matches the expected role set and is reachable through a cataloged directional composition edge."
    },
    {
      "key": "forbidden-action",
      "description": "The response avoids every authority expansion, mutation, or workflow substitution forbidden by the case."
    },
    {
      "key": "authority-boundary",
      "description": "The response keeps task authority, packet state, gateway, persistence overlay, evidence lens, transport, content, and implementation mechanics ownership distinct; no route is duplicated across roles."
    },
    {
      "key": "source-universe",
      "description": "Content owners preserve each research stage's historical, open-ended, or fixed-set source universe without turning a research workflow into the task-level authority owner."
    },
    {
      "key": "completion-gate",
      "description": "Goal and audit composition preserves measurable verification and does not claim premature completion."
    }
  ],
